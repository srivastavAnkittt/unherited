<section id="unherited-hero-{{ section.id }}" class="relative overflow-hidden">
  <style>
    #unherited-hero-{{ section.id }} {
      --brand-red: {{ section.settings.brand_red }};
      --hero-height-desktop: {{ section.settings.hero_height_desktop }}px;
      --hero-height-mobile: {{ section.settings.hero_height_mobile }}px;
    }

    #unherited-hero-{{ section.id }} .hero-wrap {
      min-height: var(--hero-height-desktop);
    }

    #unherited-hero-{{ section.id }} .serif-font {
      font-family: Georgia, "Times New Roman", serif;
    }

    @media screen and (max-width: 767px) {
      #unherited-hero-{{ section.id }} .hero-wrap {
        min-height: var(--hero-height-mobile);
      }
    }
  </style>

  <div class="hero-wrap relative flex items-center justify-center text-center">
    {% if section.settings.desktop_image != blank %}
      <picture>
        {% if section.settings.mobile_image != blank %}
          <source media="(max-width: 767px)" srcset="{{ section.settings.mobile_image | image_url: width: 900 }}">
        {% endif %}
        <img
          src="{{ section.settings.desktop_image | image_url: width: 2200 }}"
          alt="{{ section.settings.heading | escape }}"
          width="2200"
          height="1200"
          loading="eager"
          class="absolute inset-0 w-full h-full object-cover"
        >
      </picture>
    {% else %}
      <div class="absolute inset-0 bg-[#111]"></div>
    {% endif %}

    <div class="absolute inset-0 bg-black/25"></div>

    <div class="relative z-[2] px-[20px] max-w-[980px] text-white">
      {% if section.settings.heading != blank %}
        <h1 class="serif-font text-[38px] leading-[36px] md:text-[76px] md:leading-[68px] font-normal tracking-[-1px]">
          {{ section.settings.heading }}
        </h1>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <p class="mt-[16px] text-[12px] md:text-[15px] leading-normal text-white/90">
          {{ section.settings.subheading }}
        </p>
      {% endif %}

      {% if section.settings.button_text != blank %}
        <a
          href="{{ section.settings.button_link }}"
          class="inline-flex mt-[24px] px-[22px] py-[9px] bg-[var(--brand-red)] text-white text-[12px] uppercase tracking-[1px]"
        >
          {{ section.settings.button_text }}
        </a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Unherited Hero",
  "settings": [
    {
      "type": "color",
      "id": "brand_red",
      "label": "Brand red",
      "default": "#8F0000"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop hero image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile hero image"
    },
    {
  "type": "range",
  "id": "hero_height_desktop",
  "label": "Desktop height",
  "min": 400,
  "max": 1800,
  "step": 20,
  "default": 700
},
{
  "type": "range",
  "id": "hero_height_mobile",
  "label": "Mobile height",
  "min": 400,
  "max": 1600,
  "step": 20,
  "default": 560
},
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p><em>A Fragrance</em> <strong>People</strong><br/>Remember <em>You By</em></p>"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Modern luxury fragrance made for Indian homes, skin & emotion."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Unherited Hero"
    }
  ]
}
{% endschema %}