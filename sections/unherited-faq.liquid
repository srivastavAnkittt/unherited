<section id="unherited-faq-{{ section.id }}" class="bg-[var(--section-bg)] px-[16px] md:px-[40px] pb-[50px] md:pb-[70px]">
  <style>
    #unherited-faq-{{ section.id }} {
      --section-bg: {{ section.settings.bg_color }};
      --brand-red: {{ section.settings.brand_red }};
    }

    #unherited-faq-{{ section.id }} details summary::-webkit-details-marker {
      display: none;
    }

    #unherited-faq-{{ section.id }} details[open] .faq-plus {
      transform: rotate(45deg);
    }

    #unherited-faq-{{ section.id }} details[open] summary {
      background: var(--brand-red);
      color: #fff;
      padding-left: 16px;
      padding-right: 16px;
    }

    #unherited-faq-{{ section.id }} details[open] .faq-answer {
      background: var(--brand-red);
      color: #fff;
      padding-left: 16px;
      padding-right: 16px;
    }
  </style>

  {% if section.settings.heading != blank %}
    <div class="text-center mb-[22px]">
      <p class="text-[12px] uppercase tracking-[1.5px] text-black">
        — {{ section.settings.heading }} —
      </p>
    </div>
  {% endif %}

  <div class="max-w-[1180px] mx-auto border-t border-black/20">
    {% for block in section.blocks %}
      <details
        class="border-b border-black/20"
        {% if block.settings.open_by_default %}
          open
        {% endif %}
        {{ block.shopify_attributes }}
      >
        <summary class="list-none cursor-pointer flex items-center justify-between gap-[16px] py-[14px] text-[14px] md:text-[16px] transition-all duration-300">
          <span>{{ block.settings.question }}</span>
          <span class="faq-plus text-[22px] leading-none transition-transform duration-300">+</span>
        </summary>

        <div class="faq-answer pb-[16px] text-[13px] md:text-[15px] leading-[22px] text-black/70 transition-all duration-300">
          {{ block.settings.answer }}
        </div>
      </details>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Unherited FAQ",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#F3F0E5"
    },
    {
      "type": "color",
      "id": "brand_red",
      "label": "Active FAQ color",
      "default": "#8F0000"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "FAQ"
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "How do I choose the right perfume for myself?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Choose based on your personal style, usage occasion and preferred notes. Fresh notes work well for daytime, while amber, oud and deeper notes feel stronger for evening wear.</p>"
        },
        {
          "type": "checkbox",
          "id": "open_by_default",
          "label": "Open by default",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Unherited FAQ",
      "blocks": [
        {
          "type": "faq",
          "settings": {
            "question": "How do I choose the right perfume for myself?"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Do your perfumes last on both men and women?"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Are Unherited perfumes good for gifting?",
            "open_by_default": true
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Are Unherited perfumes long lasting?"
          }
        }
      ]
    }
  ]
}
{% endschema %}