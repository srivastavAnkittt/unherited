{%- comment -%}
  Section: Straight From The Community
  - Left: heading + description
  - Right: grid of review card IMAGES (uploaded via customizer blocks)
  - Fully responsive: desktop grid / mobile 1-col / 2-col / horizontal-scroll
{%- endcomment -%}

{%- assign sec_id = section.id -%}
{%- assign col_count = section.settings.desktop_columns -%}

<section
  class="community-reviews-{{ sec_id }} w-full relative"
  style="
    --cr-bg: {{ section.settings.bg_color }};
    --cr-border: {{ section.settings.border_color }};
    --cr-pad-top-d: {{ section.settings.padding_top_desktop }}px;
    --cr-pad-bottom-d: {{ section.settings.padding_bottom_desktop }}px;
    --cr-pad-top-m: {{ section.settings.padding_top_mobile }}px;
    --cr-pad-bottom-m: {{ section.settings.padding_bottom_mobile }}px;
    --cr-heading-color: {{ section.settings.heading_color }};
    --cr-heading-size-d: {{ section.settings.heading_size_desktop }}px;
    --cr-heading-size-m: {{ section.settings.heading_size_mobile }}px;
    --cr-desc-color: {{ section.settings.description_color }};
    --cr-desc-size-d: {{ section.settings.description_size_desktop }}px;
    --cr-desc-size-m: {{ section.settings.description_size_mobile }}px;
    --cr-radius: {{ section.settings.card_radius }}px;
    --cr-gap-d: {{ section.settings.card_gap_desktop }}px;
    --cr-gap-m: {{ section.settings.card_gap_mobile }}px;
    --cr-cols-d: {{ col_count }};
    --cr-max-width: {{ section.settings.max_width }}px;
  "
>
  <div class="w-full border-t-2" style="border-color: var(--cr-border); background-color: var(--cr-bg);">
    <div
      class="mx-auto flex flex-col md:flex-row items-start gap-8 md:gap-10 px-4 sm:px-6 lg:px-10 community-reviews-inner-{{ sec_id }}"
      style="max-width: var(--cr-max-width); padding-top: var(--cr-pad-top-m); padding-bottom: var(--cr-pad-bottom-m);"
    >

      <!-- LEFT: Heading + Description -->
      <div class="w-full md:w-[32%] flex-shrink-0 text-center md:text-left order-1">
        {%- if section.settings.heading != blank -%}
          <h2
            class="font-serif italic leading-tight community-reviews-heading-{{ sec_id }}"
            style="color: var(--cr-heading-color); font-size: var(--cr-heading-size-m);"
          >
            {{ section.settings.heading }}
          </h2>
        {%- endif -%}

        {%- if section.settings.description != blank -%}
          <p
            class="mt-4 community-reviews-desc-{{ sec_id }}"
            style="color: var(--cr-desc-color); font-size: var(--cr-desc-size-m);"
          >
            {{ section.settings.description }}
          </p>
        {%- endif -%}
      </div>

      <!-- RIGHT: Review Card Image Grid -->
      <div class="w-full md:w-[68%] order-2">
        {%- if section.blocks.size > 0 -%}
          <div
            class="community-reviews-grid-{{ sec_id }} community-reviews-grid layout-{{ section.settings.mobile_layout }}"
          >
            {%- for block in section.blocks -%}
              {%- if block.type == 'review_card' -%}
                <div
                  class="community-reviews-card-{{ sec_id }} overflow-hidden bg-black/5 flex items-center justify-center"
                  {{ block.shopify_attributes }}
                >
                  {%- if block.settings.card_image != blank -%}
                    <img
                      src="{{ block.settings.card_image | image_url: width: 800 }}"
                      srcset="
                        {{ block.settings.card_image | image_url: width: 400 }} 400w,
                        {{ block.settings.card_image | image_url: width: 600 }} 600w,
                        {{ block.settings.card_image | image_url: width: 800 }} 800w
                      "
                      sizes="(min-width: 768px) 33vw, 90vw"
                      width="{{ block.settings.card_image.width }}"
                      height="{{ block.settings.card_image.height }}"
                      alt="{{ block.settings.alt_text | default: 'Customer review' | escape }}"
                      loading="lazy"
                      class="w-full h-full object-cover block"
                    >
                  {%- else -%}
                    <div class="w-full h-full min-h-[220px] flex flex-col items-center justify-center bg-neutral-200 text-neutral-500 text-sm gap-2 p-4 text-center">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 opacity-60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5V7.5A1.5 1.5 0 0 1 4.5 6h15A1.5 1.5 0 0 1 21 7.5v9a1.5 1.5 0 0 1-1.5 1.5h-15A1.5 1.5 0 0 1 3 16.5Z" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="m3 15 4.5-4.5a1.5 1.5 0 0 1 2.12 0L15 15m-3-3 1.5-1.5a1.5 1.5 0 0 1 2.12 0L21 15" />
                        <circle cx="8" cy="9" r="1.25" />
                      </svg>
                      <span>Add review card image</span>
                    </div>
                  {%- endif -%}
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- else -%}
          <div class="w-full py-12 text-center text-neutral-500 border border-dashed border-neutral-300 rounded-xl">
            Add "Review Card" blocks from the section settings to display community reviews.
          </div>
        {%- endif -%}
      </div>

    </div>
  </div>
  <div class="w-full border-b-2" style="border-color: var(--cr-border); background-color: var(--cr-bg);"></div>
</section>

<style>
  .community-reviews-heading-{{ sec_id }} {
    font-size: var(--cr-heading-size-m);
  }
  .community-reviews-desc-{{ sec_id }} {
    font-size: var(--cr-desc-size-m);
  }
  .community-reviews-card-{{ sec_id }} {
    border-radius: var(--cr-radius);
  }

  /* Mobile grid layouts */
  .community-reviews-grid-{{ sec_id }}.layout-1col {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--cr-gap-m);
  }
  .community-reviews-grid-{{ sec_id }}.layout-2col {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--cr-gap-m);
  }
  .community-reviews-grid-{{ sec_id }}.layout-scroll {
    display: flex;
    gap: var(--cr-gap-m);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 8px;
  }
  .community-reviews-grid-{{ sec_id }}.layout-scroll::-webkit-scrollbar {
    height: 6px;
  }
  .community-reviews-grid-{{ sec_id }}.layout-scroll::-webkit-scrollbar-thumb {
    background: var(--cr-border);
    border-radius: 999px;
    opacity: 0.4;
  }
  .community-reviews-grid-{{ sec_id }}.layout-scroll .community-reviews-card-{{ sec_id }} {
    flex: 0 0 78%;
    scroll-snap-align: start;
  }
  .community-reviews-grid-{{ sec_id }}.layout-scroll .community-reviews-card-{{ sec_id }} img {
    min-height: 260px;
  }

  /* Desktop grid: fixed columns from schema, 2 rows worth of items wrap naturally */
  @media (min-width: 768px) {
    .community-reviews-inner-{{ sec_id }} {
      padding-top: var(--cr-pad-top-d) !important;
      padding-bottom: var(--cr-pad-bottom-d) !important;
    }
    .community-reviews-heading-{{ sec_id }} {
      font-size: var(--cr-heading-size-d);
    }
    .community-reviews-desc-{{ sec_id }} {
      font-size: var(--cr-desc-size-d);
    }
    .community-reviews-grid-{{ sec_id }} {
      display: grid !important;
      grid-template-columns: repeat(var(--cr-cols-d), minmax(0, 1fr));
      gap: var(--cr-gap-d);
      overflow: visible !important;
    }
    .community-reviews-grid-{{ sec_id }} .community-reviews-card-{{ sec_id }} {
      flex: unset;
    }
    .community-reviews-grid-{{ sec_id }} .community-reviews-card-{{ sec_id }} img {
      min-height: 0;
    }
  }
</style>

{% schema %}
{
  "name": "Community Reviews",
  "tag": "section",
  "class": "section-community-reviews",
  "settings": [
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#F1EDE4" },
    { "type": "color", "id": "border_color", "label": "Top/Bottom Border Color", "default": "#7A1F1F" },

    { "type": "header", "content": "Section Padding" },
    { "type": "range", "id": "padding_top_desktop", "min": 0, "max": 150, "step": 5, "unit": "px", "label": "Padding Top (Desktop)", "default": 60 },
    { "type": "range", "id": "padding_bottom_desktop", "min": 0, "max": 150, "step": 5, "unit": "px", "label": "Padding Bottom (Desktop)", "default": 60 },
    { "type": "range", "id": "padding_top_mobile", "min": 0, "max": 100, "step": 5, "unit": "px", "label": "Padding Top (Mobile)", "default": 30 },
    { "type": "range", "id": "padding_bottom_mobile", "min": 0, "max": 100, "step": 5, "unit": "px", "label": "Padding Bottom (Mobile)", "default": 30 },

    { "type": "header", "content": "Heading" },
    { "type": "text", "id": "heading", "label": "Heading Text", "default": "Straight From The Community!" },
    { "type": "color", "id": "heading_color", "label": "Heading Color", "default": "#7A1F1F" },
    { "type": "range", "id": "heading_size_desktop", "min": 20, "max": 80, "step": 1, "unit": "px", "label": "Heading Font Size (Desktop)", "default": 48 },
    { "type": "range", "id": "heading_size_mobile", "min": 16, "max": 48, "step": 1, "unit": "px", "label": "Heading Font Size (Mobile)", "default": 28 },

    { "type": "header", "content": "Description" },
    { "type": "textarea", "id": "description", "label": "Description Text", "default": "From first sprays to daily signatures, here's what the Tribe has been saying." },
    { "type": "color", "id": "description_color", "label": "Description Color", "default": "#333333" },
    { "type": "range", "id": "description_size_desktop", "min": 10, "max": 30, "step": 1, "unit": "px", "label": "Description Font Size (Desktop)", "default": 16 },
    { "type": "range", "id": "description_size_mobile", "min": 10, "max": 24, "step": 1, "unit": "px", "label": "Description Font Size (Mobile)", "default": 14 },

    { "type": "header", "content": "Card Layout" },
    { "type": "range", "id": "card_radius", "min": 0, "max": 40, "step": 1, "unit": "px", "label": "Card Border Radius", "default": 12 },
    { "type": "range", "id": "card_gap_desktop", "min": 0, "max": 60, "step": 2, "unit": "px", "label": "Card Gap (Desktop)", "default": 20 },
    { "type": "range", "id": "card_gap_mobile", "min": 0, "max": 40, "step": 2, "unit": "px", "label": "Card Gap (Mobile)", "default": 12 },
    {
      "type": "select",
      "id": "desktop_columns",
      "label": "Desktop Card Columns",
      "options": [
        { "value": "2", "label": "2 Columns" },
        { "value": "3", "label": "3 Columns" },
        { "value": "4", "label": "4 Columns" }
      ],
      "default": "3"
    },
    {
      "type": "select",
      "id": "mobile_layout",
      "label": "Mobile Layout",
      "options": [
        { "value": "1col", "label": "1 Column" },
        { "value": "2col", "label": "2 Columns" },
        { "value": "scroll", "label": "Horizontal Scroll" }
      ],
      "default": "scroll"
    },

    { "type": "header", "content": "Section Width" },
    { "type": "range", "id": "max_width", "min": 1000, "max": 1920, "step": 20, "unit": "px", "label": "Max Section Width", "default": 1400 }
  ],
  "blocks": [
    {
      "type": "review_card",
      "name": "Review Card",
      "settings": [
        { "type": "image_picker", "id": "card_image", "label": "Review Card Image" },
        { "type": "text", "id": "alt_text", "label": "Alt Text (optional)", "default": "Customer review" }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Community Reviews",
      "blocks": [
        { "type": "review_card" },
        { "type": "review_card" },
        { "type": "review_card" },
        { "type": "review_card" },
        { "type": "review_card" },
        { "type": "review_card" }
      ]
    }
  ]
}
{% endschema %}
