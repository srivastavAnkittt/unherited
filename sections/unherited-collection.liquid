<section id="unherited-collection-{{ section.id }}" class="bg-[var(--section-bg)]">
  <style>
    #unherited-collection-{{ section.id }} {
      --section-bg: {{ section.settings.bg_color }};
      --brand-red: {{ section.settings.brand_red }};
    }

    #unherited-collection-{{ section.id }} .serif-font {
      font-family: Georgia, "Times New Roman", serif;
    }
  </style>
<div class="page-width">
  {% if section.settings.heading != blank %}
    <div class="text-center mb-[26px]">
      <p class="text-[12px] uppercase tracking-[1.5px] text-black">
        — {{ section.settings.heading }} —
      </p>
    </div>
  {% endif %}

  <div class="!grid grid-cols-1 md:grid-cols-2">
    {% for block in section.blocks %}
      <a
        href="{{ block.settings.link }}"
        class="group relative min-h-[360px] md:min-h-[520px] overflow-hidden"
        {{ block.shopify_attributes }}
      >
        {% if block.settings.image != blank %}
          <img
            src="{{ block.settings.image | image_url: width: 1000 }}"
            alt="{{ block.settings.title | escape }}"
            width="1000"
            height="900"
            loading="lazy"
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
          >
        {% else %}
          <div class="absolute inset-0 bg-[var(--brand-red)]"></div>
        {% endif %}

        <div class="absolute inset-0 bg-black/10"></div>

        <div class="absolute left-[28px] bottom-[36px] md:left-[64px] md:bottom-[58px] z-[2] text-white">
          {% if block.settings.title != blank %}
            <h3 class="serif-font text-[34px] leading-[30px] md:text-[48px] md:leading-[43px]">
              {{ block.settings.title }}
            </h3>
          {% endif %}

          {% if block.settings.button_text != blank %}
            <span class="inline-flex mt-[16px] px-[16px] py-[8px] bg-[var(--brand-red)] text-white text-[12px] uppercase tracking-[0.8px]">
              {{ block.settings.button_text }}
            </span>
          {% endif %}
        </div>
      </a>
    {% endfor %}
  </div>
  </div>
</section>

{% schema %}
{
  "name": "Unherited Collection",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#F3F0E5"
    },
    {
      "type": "color",
      "id": "brand_red",
      "label": "Button color",
      "default": "#8F0000"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Collection"
    }
  ],
  "blocks": [
    {
      "type": "collection_card",
      "name": "Collection card",
      "limit": 2,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Fragrance for Him"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button text",
          "default": "Explore"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Unherited Collection",
      "blocks": [
        {
          "type": "collection_card",
          "settings": {
            "title": "Fragrance for Him",
            "button_text": "Explore"
          }
        },
        {
          "type": "collection_card",
          "settings": {
            "title": "Fragrance for Her",
            "button_text": "Explore"
          }
        }
      ]
    }
  ]
}
{% endschema %}