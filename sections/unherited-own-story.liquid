  "presets": [
    {
      "name": "Unherited Own Story",
      "blocks": [
        {
          "type": "paragraph",
          "settings": {
            "text": "<p>Unherited is built for those who write their own story. Quietly, boldly, unapologetically. Every fragrance we create is crafted with intent, originality, and performance at its core. We use high-quality fragrance ingredients and high perfume oil concentrations to ensure strong sillage, long-lasting performance, and a signature scent that stays with you long after the first spray.<br>But Unherited is more than a perfume brand.</p>"
          }
